# ═══════════════════════════════════════════════════
# Atheer Wallet Server — Environment Variables
# ═══════════════════════════════════════════════════

# ── قاعدة البيانات (Render يوفر DATABASE_URL تلقائياً) ──
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atheer_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT ──
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ── الخادم ──
PORT=3000
NODE_ENV=production

# ── لوحة الإدارة ──
ADMIN_EMAIL=admin@atheer.app
ADMIN_PASSWORD=admin123

# ── تشفير Atheer Token ──
ATHEER_TOKEN_KEY=12345678901234567890123456789012

# ── Atheer Switch ──
ATHEER_SWITCH_URL=https://your-switch-app.onrender.com
WALLET_API_KEY=your_wallet_secret_key_here

# ═══════════════════════════════════════════════════
# إعدادات بوابة جوالي (Jawali Gateway Simulation)
# ═══════════════════════════════════════════════════
# بيانات الوكيل (مطابقة لـ config/jawali.php)

JAWALI_BASE_URL=https://82.114.179.89:9493/paygate
JAWALI_DISABLE_SSL_VERIFICATION=true
JAWALI_MERCHANT_USERNAME=atheer_merchant
JAWALI_MERCHANT_PASSWORD=atheer_pass_123
JAWALI_MERCHANT_WALLET=777000001
JAWALI_MERCHANT_WALLET_PASSWORD=wallet_pass_123
JAWALI_MERCHANT_ORG_ID=atheer-org-001
JAWALI_MERCHANT_USER_ID=atheer.api.user
JAWALI_MERCHANT_EXTERNAL_USER=atheer_ext_1

# ★ إضافة: قيمة واسم المنظمة — مطابق لـ JawaliWalletAuthResponse
JAWALI_MERCHANT_ORG_VALUE=ORG-001
JAWALI_MERCHANT_ORG_NAME=Atheer Wallet

# صلاحية التوكنات (بالثواني) — مطابق لـ JAWALI_TIMEOUT
JAWALI_TOKEN_EXPIRY=3600
JAWALI_WALLET_TOKEN_EXPIRY=1800

# Logging (true لتفعيل تسجيل الطلبات)
JAWALI_LOGGING_ENABLED=false
