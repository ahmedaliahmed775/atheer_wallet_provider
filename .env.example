# إعدادات قاعدة البيانات
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atheer_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# إعدادات JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# إعدادات الخادم
PORT=3000
NODE_ENV=development

# إعدادات لوحة الإدارة
ADMIN_EMAIL=admin@atheer.app
ADMIN_PASSWORD=admin123

# مفتاح تشفير رمز Atheer Token (AES-256-GCM) — 32 حرفاً
ATHEER_TOKEN_KEY=12345678901234567890123456789012

# الربط مع المقسم (Atheer Switch) — بعد نشر المقسم ضع الرابط العام بـ HTTPS
ATHEER_SWITCH_URL=https://your-switch-app.ondigitalocean.app
# نفس قيمة apiKey للتاجر في جدول merchants في قاعدة المقسم (يُنشأ عبر npm run seed:merchant هناك)
WALLET_API_KEY=your_wallet_secret_key_here
