# إعدادات قاعدة البيانات
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atheer_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# إعدادات JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# إعدادات الخادم
PORT=3000
NODE_ENV=development

# إعدادات لوحة الإدارة
ADMIN_EMAIL=admin@atheer.app
ADMIN_PASSWORD=admin123

# مفتاح تشفير رمز Atheer Token (AES-256-GCM)
# يجب أن يكون بالضبط 32 حرفاً (256-bit)
# يجب أن يتطابق مع المفتاح المُعرَّف في AtheerKeystoreManager بجانب SDK الأندرويد
# مثال (للتطوير فقط — استبدله بمفتاح عشوائي آمن في الإنتاج):
ATHEER_TOKEN_KEY=12345678901234567890123456789012
\n# إعدادات الربط مع المقسم (Atheer Switch)\nATHEER_SWITCH_URL=http://switch-backend:3000\nWALLET_API_KEY=your_wallet_secret_key_here
